                                                                   "No silent failures",
                                                                   "Return count promoted"
                                                               ]
                                                  }
                                              ],
                                "invariants":  [
                                                   "Promotion path preserves deterministic CID minting and processing handoff",
                                                   "No silent partial success reporting",
                                                   "Failure paths produce deterministic error records"
                                               ],
                                "dependencies":  [
