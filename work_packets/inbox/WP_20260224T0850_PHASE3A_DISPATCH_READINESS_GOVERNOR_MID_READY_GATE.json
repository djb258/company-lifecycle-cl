    "summary":  "Implement Phase 3A Dispatch Readiness Governor (MID READY gate) as a DB-owned eligibility surface: add lcs.fn_mark_mid_ready(p_mid uuid), enforce mid_ledger FSM transitions including COMPILED-\u003eREADY path, add suppression-check stub lcs.fn_mid_suppression_check(p_mid uuid), require lcs_worker-only EXECUTE on readiness function, and prohibit direct adapter writes to mid_ledger with tests.",
    "doctrine_version":  "2.8.0",
    "timestamp":  "2026-02-24T14:40:59.8509883-05:00",
    "payload":  {
                    "phase":  "3A",
                    "src_title":  "Dispatch Readiness Governor (MID -\u003e READY Gate)",
                    "objective":  "Control when a MID is eligible for transport dispatch. No worker or adapter may send unless DB declares READY.",
                    "classification":  {
                                           "rationale":  "Feature work in LCS dispatch-state execution governance using DB functions/FSM enforcement. No protected CTB backbone, altitude, or constitutional doctrine changes.",
                                           "protected_assets_touched":  false,
                                           "parent_approval_required":  false
                                       },
                    "path_scope":  {
                                       "allowed_paths":  [
                                                             "migrations/",
                                                             "tests/"
                                                         ],
                                       "constraints":  [
                                                           "Schema/function/trigger/permission changes via migrations under migrations/",
                                                           "Tests under tests/ only",
                                                           "No changes outside allowed paths without a new WORK_PACKET"
                                                       ]
                                   },
                    "src":  {
                                "create_function":  {
                                                        "name":  "lcs.fn_mark_mid_ready",
                                                        "signature":  "lcs.fn_mark_mid_ready(p_mid uuid) returns void",
                                                        "must":  [
                                                                     "Lock row in lcs.mid_ledger",
                                                                     "Validate MID exists",
                                                                     "Validate current_dispatch_state = COMPILED",
                                                                     "Validate canonical lifecycle stage permits dispatch",
                                                                     "Enforce suppression checks: no global suppression and no active cooldown window",
                                                                     "Update current_dispatch_state = READY",
                                                                     "Update ready_at = now()",
                                                                     "On failure log deterministic row in lcs.lcs_errors and RETURN cleanly",
                                                                     "No RAISE-after-DML"
                                                                 ]
                                                    },
                                "modify_mid_ledger_fsm":  {
                                                              "target":  "lcs.mid_ledger",
                                                              "allowed_transitions":  [
                                                                                          "COMPILED -\u003e READY",
                                                                                          "READY -\u003e SENT",
                                                                                          "SENT -\u003e DELIVERED",
                                                                                          "SENT -\u003e FAILED",
                                                                                          "SENT -\u003e BOUNCED"
                                                                                      ],
                                                              "terminal_states":  [
                                                                                      "DELIVERED",
                                                                                      "FAILED",
                                                                                      "BOUNCED"
                                                                                  ],
                                                              "requirements":  [
                                                                                   "Block all transitions not explicitly allowed",
                                                                                   "Preserve loud failure behavior on illegal transition attempts"
                                                                               ]
                                                          },
                                "create_suppression_stub":  {
                                                                "name":  "lcs.fn_mid_suppression_check",
                                                                "signature":  "lcs.fn_mid_suppression_check(p_mid uuid) returns boolean",
                                                                "current_behavior":  "Always returns true",
                                                                "purpose":  "Placeholder for Phase 3B cadence/suppression engine"
                                                            },
                                "permissions":  {
                                                    "grants":  [
                                                                   "Only lcs_worker may call lcs.fn_mark_mid_ready"
                                                               ],
                                                    "prohibitions":  [
                                                                         "No direct UPDATE on lcs.mid_ledger by adapters"
                                                                     ]
                                                },
                                "non_goals":  [
                                                  "Actual transport sending",
                                                  "Adapter wiring",
                                                  "Email provider integration",
                                                  "LinkedIn integration",
                                                  "Cadence engine implementation"
                                              ]
                            },
                    "builder_outputs_expected":  [
                                                     "Migration SQL for fn_mark_mid_ready and fn_mid_suppression_check stub",
                                                     "Migration SQL for mid_ledger FSM enforcement updates (function/trigger/constraint pattern)",
                                                     "Permission/grant/revoke SQL for lcs_worker/adapters",
                                                     "Enforcement tests for READY gate, FSM transitions, suppression stub integration, and permissions"
                                                 ],
                    "test_scope":  {
                                       "include":  [
                                                       "fn_mark_mid_ready locks target MID row and validates existence/state prerequisites",
                                                       "READY gate succeeds only from COMPILED when canonical lifecycle permits dispatch",
                                                       "Suppression stub is invoked and currently allows path (returns true)",
                                                       "Failure paths log deterministic lcs.lcs_errors row and return cleanly (no raise-after-DML)",
                                                       "mid_ledger FSM allows only COMPILED-\u003eREADY, READY-\u003eSENT, SENT-\u003eDELIVERED/FAILED/BOUNCED",
                                                       "mid_ledger FSM blocks all other transitions and terminal rewinds/crossovers",
                                                       "Only lcs_worker can call fn_mark_mid_ready (where testable)",
                                                       "Adapters cannot directly UPDATE lcs.mid_ledger (where testable)"
                                                   ],
