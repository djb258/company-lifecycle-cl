    "summary":  "Implement Phase 2B Outreach Identity Resolution Governor as the mandatory pre-emission bridge: add append-only outreach.identity_resolution_errors ERROR table and outreach.fn_resolve_identity(...) with deterministic outreach_id/sovereign_id resolution, hard-fail ambiguity handling, strict JSON return shape, deterministic error logging, and EXECUTE-only sub-hub access path with tests.",
    "doctrine_version":  "2.8.0",
    "timestamp":  "2026-02-24T13:36:25.8832266-05:00",
    "payload":  {
                    "phase":  "2B",
                    "src_title":  "Outreach Identity Resolution Governor",
                    "objective":  "Enforce deterministic resolution of outreach_id and sovereign_id before any emission call.",
                    "classification":  {
                                           "rationale":  "Feature work in Outreach execution/interface layer. Adds resolver function and ERROR table enforcement without modifying protected CTB backbone, altitude hierarchy, doctrine, or constitutional assets.",
                                           "protected_assets_touched":  false,
                                           "parent_approval_required":  false
                                       },
                    "path_scope":  {
                                       "allowed_paths":  [
                                                             "migrations/",
                                                             "tests/"
                                                         ],
                                       "constraints":  [
                                                           "DB objects and permissions implemented via migrations under migrations/",
                                                           "Tests under tests/ only",
                                                           "No changes outside allowed paths without a new WORK_PACKET"
                                                       ]
                                   },
                    "src":  {
                                "trigger":  "Sub-hub detects movement and must resolve identity before any emission call.",
                                "hard_rule":  "No emission may call lcs.fn_emit_movement unless outreach.fn_resolve_identity has returned a valid outreach_id/sovereign_id pair.",
                                "create":  {
                                               "error_table":  {
                                                                   "name":  "outreach.identity_resolution_errors",
                                                                   "leaf_type":  "ERROR",
                                                                   "append_only":  true,
                                                                   "columns":  [
                                                                                   "error_id uuid primary key default gen_random_uuid()",
                                                                                   "source_schema text not null",
                                                                                   "source_table text not null",
                                                                                   "source_row_pk text not null",
                                                                                   "resolution_stage text not null",
                                                                                   "error_type text not null",
                                                                                   "error_payload jsonb not null",
                                                                                   "created_at timestamptz not null default now()",
                                                                                   "resolved_at timestamptz null"
                                                                               ],
                                                                   "constraints":  [
                                                                                       "No UPDATE except resolved_at",
                                                                                       "No DELETE"
                                                                                   ]
                                                               },
                                               "function":  {
                                                                "name":  "outreach.fn_resolve_identity",
                                                                "signature":  "outreach.fn_resolve_identity(p_source_schema text, p_source_table text, p_source_row_pk text, p_identifiers jsonb) returns jsonb",
                                                                "requirements":  [
                                                                                     "Resolve deterministic outreach_id",
                                                                                     "Resolve deterministic sovereign_id",
                                                                                     "Reject on missing anchor",
                                                                                     "Reject on multiple matches",
                                                                                     "Reject on ambiguous bridge",
                                                                                     "Insert deterministic error into outreach.identity_resolution_errors on failure",
                                                                                     "Return strict JSON only with keys outreach_id and sovereign_id on success"
                                                                                 ],
                                                                "return_contract":  {
                                                                                        "type":  "strict_json",
                                                                                        "example":  {
                                                                                                        "outreach_id":  "uuid",
                                                                                                        "sovereign_id":  "uuid"
                                                                                                    },
                                                                                        "no_free_form_payload":  true
                                                                                    }
                                                            }
                                           },
                                "permissions":  {
                                                    "sub_hubs":  "EXECUTE only",
                                                    "prohibitions":  [
                                                                         "No direct write access to canonical tables"
                                                                     ],
                                                    "ownership":  "Ownership retained by outreach schema owner"
                                                },
                                "non_goals":  [
                                                  "LCS emission implementation changes beyond enforcing precondition in tests/contracts",
                                                  "Promotion engine implementation",
                                                  "Worker automation",
                                                  "Dispatch integration",
                                                  "Cadence logic",
                                                  "UI"
                                              ]
                            },
                    "builder_outputs_expected":  [
                                                     "Migration SQL for ERROR table, permissions, and function",
                                                     "Trigger/guard enforcement for append-only error table behavior (or equivalent DB enforcement pattern)",
                                                     "Function implementation SQL",
                                                     "Permission/grant SQL",
                                                     "Enforcement tests"
                                                 ],
                    "test_scope":  {
                                       "include":  [
                                                       "Success path returns strict JSON with exactly outreach_id and sovereign_id",
                                                       "Missing anchor hard-fails and logs deterministic error row",
                                                       "Multiple matches hard-fail and log deterministic error row",
                                                       "Ambiguous bridge hard-fail and log deterministic error row",
                                                       "identity_resolution_errors blocks DELETE",
                                                       "identity_resolution_errors blocks UPDATE except resolved_at",
                                                       "Sub-hub EXECUTE-only permission path (where testable)",
                                                       "No direct canonical-table write access for sub-hub role (where testable)"
                                                   ],
                                       "exclude":  [
                                                       "LCS promotion/dispatch/cadence/UI tests",
                                                       "Worker orchestration tests"
                                                   ]
                                   },
                    "acceptance_criteria":  [
                                                "outreach.identity_resolution_errors exists with ERROR role semantics and append-only enforcement (resolved_at-only updates allowed)",
                                                "outreach.fn_resolve_identity(...) exists and returns strict JSON payload with outreach_id and sovereign_id on success",
                                                "Function hard-fails on missing anchor, multiple matches, and ambiguous bridge",
                                                "Function writes deterministic errors to outreach.identity_resolution_errors on failure",
                                                "Sub-hubs are restricted to EXECUTE-only usage of resolver function",
                                                "Tests exist and cover success, failure, and table/permission enforcement behavior"
                                            ],
