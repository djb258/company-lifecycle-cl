{
    "id":  "WP_20260224T0840_PHASE2F_WORKER_ORCHESTRATION_CONTRACT_DB_FIRST",
    "change_type":  "feature",
    "architectural_flag":  false,
    "allowed_paths":  [
                          "migrations/",
                          "tests/"
                      ],
    "summary":  "Implement Phase 2F Worker Orchestration Contract as a DB-first execution surface (no Docker): add append-only lcs.worker_run_log SUPPORTING table, create lcs.fn_worker_tick(...) dispatcher over promotion/finalize batch functions with run logging and JSON result payload, and enforce lcs_worker EXECUTE-only permissions with no direct table writes.",
    "doctrine_version":  "2.8.0",
    "timestamp":  "2026-02-24T14:39:10.8658152-05:00",
    "payload":  {
                    "phase":  "2F",
                    "src_title":  "Worker Orchestration Contract (DB-First, No Sideways Writes)",
                    "objective":  "Create the DB-owned execution surface the worker uses, without building Docker yet.",
                    "classification":  {
                                           "rationale":  "Feature work within LCS execution/interface layer. Adds DB-owned orchestration surface and least-privilege role without modifying protected CTB backbone, altitude hierarchy, or constitutional doctrine assets.",
                                           "protected_assets_touched":  false,
                                           "parent_approval_required":  false
                                       },
                    "path_scope":  {
                                       "allowed_paths":  [
                                                             "migrations/",
                                                             "tests/"
                                                         ],
                                       "constraints":  [
                                                           "Schema/functions/roles/grants implemented via migrations under migrations/",
                                                           "Tests under tests/ only",
                                                           "No changes outside allowed paths without a new WORK_PACKET"
                                                       ]
                                   },
                    "src":  {
                                "create_supporting_table":  {
                                                                "name":  "lcs.worker_run_log",
                                                                "leaf_type":  "SUPPORTING",
                                                                "append_only":  true,
                                                                "ctb_registration_required":  true,
                                                                "columns":  [
                                                                                "run_id uuid primary key default gen_random_uuid()",
                                                                                "run_type text not null  (PROMOTE_EMISSIONS | FINALIZE_DISPATCH)",
                                                                                "started_at timestamptz not null default now()",
                                                                                "finished_at timestamptz null",
                                                                                "status text not null (STARTED | SUCCESS | PARTIAL | FAIL)",
                                                                                "attempted_count int not null default 0",
                                                                                "success_count int not null default 0",
                                                                                "error_count int not null default 0",
                                                                                "notes jsonb null"
                                                                            ],
                                                                "constraints":  [
                                                                                    "Append-only semantics (no UPDATE/DELETE except implementation may permit run completion updates if modeled as same-row lifecycle; if so, Builder must document and test exact mutation allowances)",
                                                                                    "Register in CTB with SUPPORTING leaf type using repo-existing registry table"
                                                                                ]
                                                            },
                                "create_worker_entry_function":  {
                                                                     "name":  "lcs.fn_worker_tick",
                                                                     "signature":  "lcs.fn_worker_tick(p_run_type text, p_limit int default 250) returns jsonb",
                                                                     "must":  [
                                                                                  "Insert lcs.worker_run_log STARTED row",
                                                                                  "If p_run_type = PROMOTE_EMISSIONS, call lcs.fn_promote_emission_batch(p_limit)",
                                                                                  "If p_run_type = FINALIZE_DISPATCH, call lcs.fn_finalize_dispatch_batch(p_limit) (create stub if not present)",
                                                                                  "Update run_log with counts + status",
                                                                                  "Return strict JSON summary payload",
                                                                                  "No RAISE-after-DML"
                                                                              ],
                                                                     "return_contract":  {
                                                                                             "type":  "jsonb",
                                                                                             "required_keys":  [
                                                                                                                   "run_id",
                                                                                                                   "run_type",
                                                                                                                   "attempted",
                                                                                                                   "success",
                                                                                                                   "errors",
                                                                                                                   "status"
                                                                                                               ],
                                                                                             "example":  {
                                                                                                             "run_id":  "uuid",
                                                                                                             "run_type":  "PROMOTE_EMISSIONS",
                                                                                                             "attempted":  250,
                                                                                                             "success":  187,
                                                                                                             "errors":  63,
                                                                                                             "status":  "PARTIAL"
                                                                                                         }
                                                                                         },
                                                                     "run_type_dispatch":  {
                                                                                               "PROMOTE_EMISSIONS":  "lcs.fn_promote_emission_batch(p_limit)",
                                                                                               "FINALIZE_DISPATCH":  "lcs.fn_finalize_dispatch_batch(p_limit) (stub allowed if missing)"
                                                                                           }
                                                                 },
                                "permissions":  {
                                                    "create_role":  "lcs_worker",
                                                    "grants":  [
                                                                   "Grant EXECUTE on lcs.fn_worker_tick to lcs_worker"
                                                               ],
                                                    "prohibitions":  [
                                                                         "No direct table writes granted",
                                                                         "Revoke everything else for lcs_worker"
                                                                     ]
                                                },
                                "non_goals":  [
                                                  "Docker worker",
                                                  "Scheduling/cron",
                                                  "Transport adapter code",
                                                  "UI"
                                              ]
                            },
                    "builder_outputs_expected":  [
                                                     "Migration SQL for lcs.worker_run_log and CTB registration entry",
                                                     "Migration SQL for lcs.fn_worker_tick(...) and finalize batch stub if needed",
                                                     "Role/grant/revoke SQL for lcs_worker least-privilege access",
                                                     "Enforcement and function behavior tests"
                                                 ],
                    "test_scope":  {
                                       "include":  [
                                                       "worker_run_log table exists with expected columns and SUPPORTING registration",
                                                       "fn_worker_tick inserts STARTED run log row and returns JSON with required keys",
                                                       "PROMOTE_EMISSIONS path dispatches to fn_promote_emission_batch(p_limit)",
                                                       "FINALIZE_DISPATCH path dispatches to fn_finalize_dispatch_batch(p_limit) or valid stub",
                                                       "run_log row updates counts/status/finished_at deterministically",
                                                       "No RAISE-after-DML behavior (errors reflected in status/result instead of post-DML exception)",
                                                       "lcs_worker role has EXECUTE on fn_worker_tick",
                                                       "lcs_worker lacks direct table write privileges and other revoked privileges (where testable)"
                                                   ],
                                       "exclude":  [
                                                       "Docker/scheduler/transport adapter/UI tests"
                                                   ]
                                   },
                    "acceptance_criteria":  [
                                                "lcs.worker_run_log exists and is CTB-registered as SUPPORTING",
                                                "lcs.fn_worker_tick(p_run_type text, p_limit int default 250) exists and returns the required JSON contract",
                                                "PROMOTE_EMISSIONS and FINALIZE_DISPATCH dispatch paths are implemented (stub permitted for finalize batch if absent)",
                                                "Run logging records STARTED and completion counts/status deterministically",
                                                "No direct table writes are granted to lcs_worker and only EXECUTE on fn_worker_tick is granted",
                                                "Tests exist and cover dispatcher behavior, JSON contract, logging, and permissions"
                                            ],
                    "artifacts":  {
                                      "expected":  [
                                                       "WP_*.json",
                                                       "CS_*.json",
                                                       "AR_*.json"
                                                   ]
                                  }
                }
}
