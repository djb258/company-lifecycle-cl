    "summary":  "Implement Phase 3C Transport Adapter Contract (external boundary lock): create the only legal DB entry point lcs.fn_record_dispatch_result(...) for transport result reporting, add append-only lcs.dispatch_event_log SUPPORTING table, enforce SENT-\u003eterminal result validation and forward-only FSM on mid_ledger updates, and restrict lcs_transport to EXECUTE-only with no direct table writes.",
    "doctrine_version":  "2.8.0",
    "timestamp":  "2026-02-24T15:08:46.4716906-05:00",
    "payload":  {
                    "phase":  "3C",
                    "src_title":  "Transport Adapter Contract (External Boundary Lock)",
                    "objective":  "Create the only legal DB entry point for transport result reporting. No adapter may mutate mid_ledger directly.",
                    "classification":  {
                                           "rationale":  "Feature work at the DB external-boundary interface for transport result reporting. Adds function/table/permissions within existing LCS governance surfaces without modifying protected CTB backbone, altitude hierarchy, or constitutional doctrine assets.",
                                           "protected_assets_touched":  false,
                                           "parent_approval_required":  false
                                       },
                    "path_scope":  {
                                       "allowed_paths":  [
                                                             "migrations/",
                                                             "tests/"
                                                         ],
                                       "constraints":  [
                                                           "Schema/function/trigger/role/grant changes via migrations under migrations/",
                                                           "Tests under tests/ only",
                                                           "No changes outside allowed paths without a new WORK_PACKET"
                                                       ]
                                   },
                    "src":  {
                                "create_function":  {
                                                        "name":  "lcs.fn_record_dispatch_result",
                                                        "signature":  "lcs.fn_record_dispatch_result(p_mid uuid, p_provider text, p_external_message_id text, p_result_state text, p_metadata jsonb) returns void",
                                                        "requirements":  [
                                                                             "SELECT ... FOR UPDATE the mid row",
                                                                             "Validate current_dispatch_state = SENT",
                                                                             "Validate p_result_state in {DELIVERED, FAILED, BOUNCED}",
                                                                             "Enforce forward-only FSM (reuse existing guard)",
                                                                             "Update current_dispatch_state",
                                                                             "Update provider",
                                                                             "Update external_message_id",
                                                                             "Update delivered_at / failed_at / bounced_at as applicable",
                                                                             "INSERT deterministic row into lcs.dispatch_event_log",
                                                                             "No RAISE-after-DML"
                                                                         ]
                                                    },
                                "create_supporting_table":  {
                                                                "name":  "lcs.dispatch_event_log",
                                                                "leaf_type":  "SUPPORTING",
                                                                "append_only":  true,
                                                                "ctb_registration_required":  true,
                                                                "columns":  [
                                                                                "event_id uuid primary key",
                                                                                "mid uuid not null",
                                                                                "provider text not null",
                                                                                "external_message_id text",
                                                                                "result_state text not null",
                                                                                "metadata jsonb",
                                                                                "recorded_at timestamptz default now()"
                                                                            ],
                                                                "requirements":  [
                                                                                     "Append-only enforcement",
                                                                                     "CTB register as SUPPORTING using repo-existing registry table",
                                                                                     "FK to lcs.mid_ledger(mid) where applicable"
                                                                                 ]
                                                            },
                                "permissions":  {
                                                    "create_role":  "lcs_transport",
                                                    "grants":  [
                                                                   "Grant EXECUTE on lcs.fn_record_dispatch_result to lcs_transport"
                                                               ],
                                                    "revokes":  [
                                                                    "Revoke ALL on lcs.mid_ledger from lcs_transport",
                                                                    "Revoke ALL on lcs.dispatch_event_log from lcs_transport"
                                                                ],
                                                    "policy":  "Only function mediates writes"
                                                },
                                "hard_rule":  "No transport adapter writes to tables directly. All dispatch outcomes go through this function.",
                                "non_goals":  [
                                                  "Actual Mailgun/SES integration",
                                                  "Webhook endpoint",
                                                  "Retry policy",
                                                  "Bounce processing automation"
                                              ]
                            },
                    "builder_outputs_expected":  [
                                                     "Migration SQL for lcs.dispatch_event_log and CTB SUPPORTING registration entry",
                                                     "Migration SQL for lcs.fn_record_dispatch_result(...)",
                                                     "Permission/grant/revoke SQL for lcs_transport least-privilege access",
                                                     "Any trigger/FSM reuse wiring needed for forward-only enforcement",
                                                     "Enforcement tests for function behavior, event logging, and permissions"
                                                 ],
                    "test_scope":  {
                                       "include":  [
                                                       "fn_record_dispatch_result locks target mid row and validates current_dispatch_state = SENT",
                                                       "Function rejects invalid p_result_state values outside {DELIVERED, FAILED, BOUNCED}",
                                                       "Function enforces forward-only FSM using existing guard",
                                                       "Function updates mid_ledger state/provider/external_message_id and correct timestamp column for DELIVERED/FAILED/BOUNCED",
                                                       "Function inserts deterministic append-only row into lcs.dispatch_event_log",
                                                       "Failure paths do not raise after DML (clean return/controlled behavior)",
                                                       "lcs.dispatch_event_log is append-only and CTB-registered as SUPPORTING",
                                                       "lcs_transport has EXECUTE on function but no direct privileges on mid_ledger/dispatch_event_log (where testable)"
                                                   ],
                                       "exclude":  [
                                                       "Provider integration/webhook tests",
                                                       "Retry/bounce automation tests",
                                                       "UI tests"
                                                   ]
                                   },
                    "acceptance_criteria":  [
                                                "lcs.fn_record_dispatch_result(...) exists as the DB entry point for transport result reporting",
                                                "Function validates SENT state and allowed terminal result states and enforces forward-only FSM",
                                                "Function updates mid_ledger outcome fields and timestamps and records a deterministic lcs.dispatch_event_log row",
                                                "lcs.dispatch_event_log exists, is append-only, and is CTB-registered as SUPPORTING",
                                                "lcs_transport role exists with EXECUTE on function and no direct table write/read privileges as specified",
                                                "Tests exist and verify boundary lock, function behavior, event logging, and permission enforcement"
                                            ],
                    "artifacts":  {
                                      "expected":  [
                                                       "WP_*.json",
                                                       "CS_*.json",
                                                       "AR_*.json"
                                                   ]
                                  }
                }
