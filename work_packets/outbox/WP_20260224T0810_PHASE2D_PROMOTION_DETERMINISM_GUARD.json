                                                           "Tests under tests/ only",
                                                           "No changes outside allowed paths without a new WORK_PACKET"
                                                       ]
                                   },
                    "src":  {
                                "create_or_modify":  {
                                                         "constraint_changes":  [
                                                                                    {
                                                                                        "target":  "lcs.cid_intake",
                                                                                        "action":  "Add UNIQUE constraint",
                                                                                        "definition":  "UNIQUE (emission_id)",
                                                                                        "conditional":  "If emission_id column not present, add emission_id uuid not null first",
                                                                                        "data_requirement":  "emission_id must be backfilled/populated by promotion function path"
                                                                                    }
                                                                                ],
                                                         "function_changes":  [
                                                                                  {
                                                                                      "target":  "lcs.fn_promote_emission(p_emission_id uuid) returns void",
                                                                                      "must":  [
                                                                                                   "Before INSERT, check whether emission already has promoted_cid; if yes RETURN cleanly (idempotent)",
                                                                                                   "INSERT into cid_intake includes emission_id",
                                                                                                   "Use ON CONFLICT (emission_id) DO NOTHING",
                                                                                                   "If conflict occurs, SELECT existing CID, update emission status = PROMOTED, and RETURN",
                                                                                                   "Do not RAISE on replay/conflict path"
                                                                                               ]
                                                                                  },
                                                                                  {
                                                                                      "target":  "lcs.fn_promote_emission_batch(p_limit int) returns int",
                                                                                      "must":  [
                                                                                                   "Tolerate concurrent execution",
                                                                                                   "Use FOR UPDATE SKIP LOCKED",
                                                                                                   "Prevent duplicate CID minting under parallel workers"
                                                                                               ]
                                                                                  }
                                                                              ]
                                                     },
                                "hard_rules":  [
                                                   "One emission -\u003e one CID",
                                                   "Replays are safe",
                                                   "Parallel workers cannot produce duplicate CIDs",
                                                   "Status transitions remain forward-only"
                                               ],
