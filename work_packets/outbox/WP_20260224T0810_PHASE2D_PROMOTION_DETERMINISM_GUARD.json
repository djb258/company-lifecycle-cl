                    "objective":  "Prevent duplicate CID minting and ensure emission replay safety under concurrency.",
                    "classification":  {
                                           "rationale":  "Targeted LCS enforcement hardening (idempotency/concurrency safety) within existing execution surfaces; no protected CTB/backbone/altitude/doctrine changes.",
                                           "protected_assets_touched":  false,
                                           "parent_approval_required":  false
                                       },
                    "path_scope":  {
                                       "allowed_paths":  [
                                                             "migrations/",
                                                             "tests/"
                                                         ],
